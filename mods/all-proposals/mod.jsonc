{
	"id": "all-proposals",
	"name": "All Proposals",
	"authors": [ "CJFWeatherhead" ],
	"version": "2.0.2",
	"description": [
		"Enhances the game's proposal system by allowing players to view all available proposals at once. Press SHIFT+O to show all eligible proposals (excluding those with unmet dependencies or failed adhoc requirements). Press SHIFT+U to restore the normal proposal batch size. No panels, no console commands — keyboard shortcuts only."
	],
	"links": {
		"github": "https://github.com/CJFWeatherhead/TNI-Mods/tree/beta/mods/all-proposals",
		"lua": "https://lua.org/",
		"luajit": "https://luajit.org/",
		"Click here to see all of my other mods!": "https://tower.networking.ink/mods"
	},
	"dependencies": {
		// See https://devhints.io/semver for syntax.
		"tower-networking-inc": "^0.10.7",
		"luajit-support": "~0.2.0"
	},
	"dependencies_optional": {
		"supa-mod-loader": ">=4.0.0"
	},
	"incompatibilities": {
	}
}
